ALPACA_API_KEY=
ALPACA_SECRET_KEY=
FINNHUB_API_KEY=

SESSION_MODE=auto
SPIKE_THRESHOLD=1.5
SPIKE_WINDOW=5
POLL_INTERVAL=30

GAP_THRESHOLD=100
PREOPEN_WINDOW=10
PREOPEN_SETTLE_MINUTES=1
PREOPEN_THRESHOLD=1.0
PREOPEN_RANGE_THRESHOLD=1.5
PREOPEN_MIN_DOLLAR_VOLUME=2500000
PREOPEN_MAX_RESULTS=8

# preopen target mode:
#   dynamic -> scales target % from detected preopen volatility
#   fixed   -> always uses PREOPEN_TARGET_MOVE_PCT
PREOPEN_TARGET_MODE=dynamic
PREOPEN_TARGET_MOVE_PCT=2.0
PREOPEN_TARGET_MIN_PCT=0.5
PREOPEN_TARGET_MAX_PCT=4.0
PREOPEN_TARGET_SCALE=0.25

# Replay controls
BACKTEST_TIME=2025-04-07T13:25:00Z
BACKTEST_STEP=1
REPLAY_DELAY=1
REPLAY_TICKS=10

NEWS_LOOKBACK_SPIKE_DAYS=1
NEWS_LOOKBACK_GAP_DAYS=7

# Scanner event runner defaults (intraday)
SCANNER_EVENTS_MODE=auto
INTRADAY_EVENT_DURATION_SECONDS=180
INTRADAY_STEP_SECONDS=30

# target mode:
#   dynamic -> scales target % from detected spike magnitude (recommended)
#   fixed   -> always uses INTRADAY_TARGET_MOVE_PCT
INTRADAY_TARGET_MODE=dynamic
INTRADAY_TARGET_MOVE_PCT=5
INTRADAY_TARGET_MIN_PCT=0.5
INTRADAY_TARGET_MAX_PCT=3.0
INTRADAY_TARGET_SCALE=0.35

EVENT_ID_START=1
